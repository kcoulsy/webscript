{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "<",
      ">"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(?:@(?:load|client|action|component|layout|do|if|for|style)(?:\\b|\\s).*)\\{\\s*$|^\\s*<([A-Za-z][\\w.-]*)(?:\\s[^>]*)?>\\s*$",
      "end": "^\\s*\\}\\s*(?:@else\\s*\\{\\s*)?$|^\\s*</[A-Za-z][\\w.-]*>\\s*$"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!#$%^&*()+\\-=\\[\\]{}\\\\|;:'\",.<>/?\\s]+)"
}
