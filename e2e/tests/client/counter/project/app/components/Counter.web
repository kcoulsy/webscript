@component Counter {
  initial: int = 0
  label: string = "Count"
}

@client {
  count: signal<int> = initial
}

<div class="counter">
  <p class="counter-label">{label}: <span>{count}</span></p>
  <div class="button-row">
    <button type="button" @click={count++}>+</button>
    <button type="button" @click={count--}>-</button>
    <button type="button" @click={count = 0}>Reset</button>
  </div>
</div>
