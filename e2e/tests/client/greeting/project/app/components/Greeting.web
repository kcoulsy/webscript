@component Greeting {
  placeholder: string = "Your name"
}

@client {
  name: signal<string> = ""
}

<div class="greeting">
  <label for="greeting-name">Name</label>
  <input
    id="greeting-name"
    value={name}
    placeholder={placeholder}
    @input={|event| name = event.target.value}
  />
  <p class="greeting-output">Hello, <span>{name}</span>!</p>
</div>
