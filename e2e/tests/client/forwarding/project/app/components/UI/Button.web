@component UI.Button {
  label: string
  variant: string = "default"
  size: string = "default"
  type: string = "button"
  disabled: bool = false
  class: string = ""
}

@if disabled {
  <button type={type} class={"ui-button " + class} data-variant={variant} data-size={size} data-ws-bind disabled>
    @switch size {
      @case "icon" {
        <span class="ui-button-icon-label">{label}</span>
      }
      @default {
        {label}
      }
    }
  </button>
} @else if variant == "link" {
  <button type={type} class={"ui-button " + class} data-variant={variant} data-size={size} data-ws-bind>
    @switch size {
      @case "icon" {
        <span class="ui-button-icon-label">{label}</span>
      }
      @default {
        {label}
      }
    }
  </button>
} @else {
  <button type={type} class={"ui-button " + class} data-variant={variant} data-size={size} data-ws-bind>
    @switch size {
      @case "icon" {
        <span class="ui-button-icon-label">{label}</span>
      }
      @default {
        {label}
      }
    }
  </button>
}
