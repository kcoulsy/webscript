@page "/"

@let name: string = "WebScript"
@let showIntro: bool = false
@let posts: string[] = ["One", "Two", "Three"]

<main>
  <h1>Hello {name}</h1>

  @if showIntro {
    <p>The MVP runtime is serving this directly from a .web file.</p>
  } @else {
    <p>The intro is hidden.</p>
  }

  <h2>Posts</h2>
  @for post in posts {
    <p>{post}</p>
  }
</main>
