@page "/todos"

@load {
  todos: Todo[] = await Todo.all()

    _: object = await sleep(25ms)
    _: object = await sleep(25ms)
}

@action addTodo {
  if input.title == "" {
    fail("Write a todo before adding it.")
  }
  await Todo.create(input)
  redirect("/todos")
}

@action completeTodo {
  if input.id == "" {
    fail("Unknown todo.")
  }
  await Todo.update(input.id, { done: true })
  redirect("/todos")
}

@action resetTodos {
  await Todo.deleteAll()
  redirect("/todos")
}

<main>
  <h1>Todo app</h1>
  <p>A tiny database-backed todo list for the example app.</p>

  <form method="post" action="/todos">
    <input type="hidden" name="_action" value="addTodo" />
    <label>
      New todo
      <input name="title" placeholder="Ship something small" />
    </label>
    <button>Add todo</button>
  </form>

  @if todos.length > 0 {
    <section>
      <h2>Todos</h2>

      @for todo in todos {
        <TodoItem title={todo.title} done={todo.done} />
        @if !todo.done {
          <form method="post" action="/todos">
            <input type="hidden" name="_action" value="completeTodo" />
            <input type="hidden" name="id" value={todo.id} />
            <button>Mark done</button>
          </form>
        }
      }

      <form method="post" action="/todos">
        <input type="hidden" name="_action" value="resetTodos" />
        <button>Reset list</button>
      </form>
    </section>
  } @else {
    <p>No todos yet. Add one above.</p>
  }
</main>
