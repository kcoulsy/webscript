@page "/todos"

@load {
  todos: Todo[] = await Todo.all()

    _: object = await sleep(25ms)
    _: object = await sleep(25ms)
}

@action addTodo {
  if input.title == "" {
    fail("Write a todo before adding it.")
  }
  await Todo.create(input)
  redirect("/todos")
}

@action completeTodo {
  if input.id == "" {
    fail("Unknown todo.")
  }
  await Todo.update(input.id, { done: true })
  redirect("/todos")
}

@action resetTodos {
  await Todo.deleteAll()
  redirect("/todos")
}

<main>
  <h1>Todo app</h1>
  <p>A tiny database-backed todo list for the example app.</p>

  <form method="post" action="/todos" class="form-stack">
    <input type="hidden" name="_action" value="addTodo" />
    <UI.Label text="New todo" target="todo-title" />
    <UI.Input id="todo-title" name="title" placeholder="Ship something small" required=true />
    <UI.Button label="Add todo" type="submit" />
  </form>

  @if todos.length > 0 {
    <section>
      <h2>Todos</h2>

      @for todo in todos {
        <TodoItem title={todo.title} done={todo.done} />
        @if !todo.done {
          <form method="post" action="/todos" class="button-row" style="margin: 0.5rem 0 1rem;">
            <input type="hidden" name="_action" value="completeTodo" />
            <input type="hidden" name="id" value={todo.id} />
            <UI.Button label="Mark done" type="submit" size="sm" variant="outline" />
          </form>
        }
      }

      <form method="post" action="/todos" class="button-row">
        <input type="hidden" name="_action" value="resetTodos" />
        <UI.Button label="Reset list" type="submit" variant="destructive" size="sm" />
      </form>
    </section>
  } @else {
    <p>No todos yet. Add one above.</p>
  }
</main>
