@page "/fetch-demo"

@load {
  title: string = ""
  completed: bool = false
  error: string = ""

  try {
    todo: JsonPlaceholderTodo = await fetch("https://jsonplaceholder.typicode.com/todos/1", JsonPlaceholderTodo)
    title = todo.title
    completed = todo.completed
  } catch err {
    error = err.message
  }
}

<main>
  <h1>Fetch demo</h1>
  <p>Demonstrates <code>fetch</code> with <code>@schema</code>, <code>throw</code>, and <code>try/catch</code>.</p>
  <p>Title: {title}</p>
  <p>Completed: {completed}</p>
  <p>Error: {error}</p>
  <nav>
    <a href="/">Home</a>
    <a href="/async-demo">Async demo</a>
  </nav>
</main>
