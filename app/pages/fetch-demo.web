@page "/fetch-demo"

@load {
  origin: string = ""
  url: string = ""
  error: string = ""

  try {
    data: HttpBinGet = await fetch("https://httpbin.org/get", HttpBinGet)
    origin = data.origin
    url = data.url
  } catch err {
    error = err.message
  }
}

<main>
  <h1>Fetch demo</h1>
  <p>Demonstrates <code>fetch</code> with <code>@schema</code>, <code>throw</code>, and <code>try/catch</code>.</p>
  <p>Origin: {origin}</p>
  <p>URL: {url}</p>
  <p>Error: {error}</p>
  <nav>
    <a href="/">Home</a>
    <a href="/async-demo">Async demo</a>
  </nav>
</main>
