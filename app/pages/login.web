@page "/login"

@load {
  loggedIn: bool = session.userId != 0
}

@action login(input: LoginForm) {
  user: User = await User.findByEmail(input.email)

  if user.id == 0 || !crypto.verifyPassword(input.password, user.passwordHash) {
    fail("Invalid email or password")
  }

  session.userId = user.id
  redirect("/dashboard")
}

<main class="auth-page">
  <div class="auth-card">
    @if loggedIn {
      <div class="auth-card-header">
        <h1>You're signed in</h1>
        <p>Head to your dashboard to see your account details.</p>
      </div>
      <a href="/dashboard" class="auth-link-button">Go to dashboard</a>
    } @else {
      <div class="auth-card-header">
        <h1>Welcome back</h1>
        <p>Sign in to access your dashboard and demos.</p>
      </div>

      <form method="post" action="/login" class="auth-form">
        <input type="hidden" name="_action" value="login" />
        <div>
          <UI.Label text="Email" target="login-email" />
          <UI.Input id="login-email" name="email" type="email" placeholder="you@example.com" required=true />
        </div>
        <div>
          <UI.Label text="Password" target="login-password" />
          <UI.Input id="login-password" name="password" type="password" placeholder="Enter your password" required=true />
        </div>
        <UI.Button label="Log in" type="submit" class="auth-submit" />
      </form>

      <p class="auth-footer">
        No account yet? <a href="/register">Create one</a>
      </p>
    }
  </div>
</main>
