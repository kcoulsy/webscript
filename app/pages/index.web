@page "/"

@let name = "aaa"
@let visits = 2 + 3
@let greeting = "Hello " + name
@let ready = visits == 5 && name != "Guest"
@let boosted = (visits + 1) > 5
@let posts: string[] = ["One", "Two", "Three"]

<main>
  <h1>{greeting}</h1>
  <p>Visit count: {visits + 1}</p>

  @if ready && !false {
    <p>The expression engine is running this page directly from app/pages/index.web.</p>
  } @else {
    <p>The intro is hidden.</p>
  }

  <h2>Posts</h2>
  <PostPreview title={"Pinned for " + name} rank={visits - 4} featured={boosted || ready} />

  @for post in posts {
    <PostPreview title={post} featured={post == "One" || boosted} />
  }
</main>
