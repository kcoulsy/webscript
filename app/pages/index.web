@page "/"

@let name = "aaa"
@let visits = 2 + 3
@let greeting = "Hello " + name
@let ready = visits == 5 && name != "Guest"
@let boosted = (visits + 1) > 5
@let author = {
  name: "Ada"
  role: "admin"
}
@let posts = [
  { title: "Intro", slug: "intro", featured: true },
  { title: "Launch", slug: "launch", featured: false },
  { title: "Roadmap", slug: "roadmap", featured: false }
]

@action increment {
  session.count = session.count + 1
  redirect("/")
}

@action rememberName {
  if input.name == "" {
    fail("Name is required")
  }
  session.name = input.name
  redirect("/")
}

<main>
  <h1>{greeting}</h1>
  <p>Author: {author.name} ({author.role})</p>
  <p>Visit count: {visits + 1}</p>
  <p>Session count: {session.count}</p>
  <p>Remembered name: {session.name}</p>
  <form method="post" action="/">
    <input type="hidden" name="_action" value="increment" />
    <button>Increment session</button>
  </form>
  <form method="post" action="/">
    <input type="hidden" name="_action" value="rememberName" />
    <input name="name" value={session.name} />
    <button>Remember name</button>
  </form>

  @if ready && !false {
    <p>The expression engine is running this page directly from app/pages/index.web.</p>
  } @else {
    <p>The intro is hidden.</p>
  }

  <h2>Posts</h2>
  <PostPreview title={"Pinned for " + author.name} rank={visits - 4} featured={boosted || ready} />

  @for post in posts {
    <PostPreview
      title={post.title}
      featured={post.featured}
    />
  }
</main>
