@page "/"

@let name: string = "sdf"
@let showIntro: bool = false
@let posts: string[] = ["One", "Two", "Three"]

<main>
  <h1>Hello {name}</h1>

  @if showIntro {
    <p>This page is served directly from app/pages/index.web.</p>
  } @else {
    <p>The intro is hidden.</p>
  }

  <h2>Posts</h2>
  <PostPreview title="Pinned release notes" rank=1 featured=true />

  @for post in posts {
    <PostPreview title={post} />
  }
</main>
