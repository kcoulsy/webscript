@component Details {
  title: string = "Details"
}

@client {
  open: signal<bool> = false
}

<section class="details">
  <button type="button" class="ui-button" data-variant="outline" data-size="sm" @click={open = !open}>
    @if open {
      Hide {title}
    } @else {
      Show {title}
    }
  </button>

  @if open {
    <div class="details-panel">
      <UI.Card
        title={title}
        content="Content loaded on the server, toggled in the browser."
      />
    </div>
  }
</section>

@style {
  .details-panel {
    margin-top: 0.75rem;
  }
}
