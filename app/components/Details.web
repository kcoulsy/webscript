@component Details {
  title: string = "Details"
}

@client {
  open: signal<bool> = false
}

<section class="details">
  <button @click={open = !open}>
    @if open {
      Hide {title}
    } @else {
      Show {title}
    }
  </button>

  @if open {
    <div class="details-panel" style="margin-top: 0.75rem; padding: 0.75rem 1rem; border: 1px solid #ccc; border-radius: 6px; background: #f8f8f8;">
      <p><strong>{title}</strong> — content loaded on the server, toggled in the browser.</p>
    </div>
  }
</section>
