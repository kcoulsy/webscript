@component Details {
  title: string = "Details"
}

@client {
  open: signal<bool> = false
}

<section class="details">
  @if open {
    <UI.Button label={"Hide " + title} variant="outline" size="sm" @click={open = !open} />
  } @else {
    <UI.Button label={"Show " + title} variant="outline" size="sm" @click={open = !open} />
  }

  @if open {
    <div class="details-panel">
      <UI.Card
        title={title}
        content="Content loaded on the server, toggled in the browser."
      />
    </div>
  }
</section>

@style {
  .details-panel {
    margin-top: 0.75rem;
  }
}
