@component TodoItem {
  title: string
  done: bool = false
}

<article class="todo-item">
  @if done {
    <UI.Badge text="Done" variant="secondary" />
  } @else {
    <UI.Badge text="Next" variant="outline" />
  }
  <p>{title}</p>
</article>

@style {
  .todo-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--ui-border);
  }

  .todo-item p {
    margin: 0;
    font-size: 0.9375rem;
  }
}
