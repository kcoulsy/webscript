@component UI.Separator {
  orientation: string = "horizontal"
}

@if orientation == "vertical" {
  <div class="ui-separator" data-orientation="vertical" role="separator" aria-orientation="vertical"></div>
} @else {
  <div class="ui-separator" data-orientation="horizontal" role="separator" aria-orientation="horizontal"></div>
}

@style {
  .ui-separator {
    flex-shrink: 0;
    background: var(--ui-border);
  }

  .ui-separator[data-orientation="horizontal"] {
    width: 100%;
    height: 1px;
    margin: 1rem 0;
  }

  .ui-separator[data-orientation="vertical"] {
    width: 1px;
    height: 100%;
    min-height: 1.5rem;
    margin: 0 1rem;
  }
}
