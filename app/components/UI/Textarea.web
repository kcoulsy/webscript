@component UI.Textarea {
  name: string = ""
  value: string = ""
  placeholder: string = ""
  rows: int = 4
  disabled: bool = false
  required: bool = false
}

@if disabled {
  <textarea
    class="ui-textarea"
    name={name}
    rows={rows}
    placeholder={placeholder}
    disabled
  >{value}</textarea>
} @else {
  @if required {
    <textarea
      class="ui-textarea"
      name={name}
      rows={rows}
      placeholder={placeholder}
      required
    >{value}</textarea>
  } @else {
    <textarea
      class="ui-textarea"
      name={name}
      rows={rows}
      placeholder={placeholder}
    >{value}</textarea>
  }
}

@style {
  .ui-textarea {
    display: flex;
    width: 100%;
    min-height: 5rem;
    border-radius: var(--ui-radius);
    border: 1px solid var(--ui-input);
    background: transparent;
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    color: var(--ui-foreground);
    font-family: inherit;
    line-height: 1.5;
    resize: vertical;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .ui-textarea::placeholder {
    color: var(--ui-muted-foreground);
  }

  .ui-textarea:focus {
    outline: none;
    border-color: var(--ui-ring);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ui-ring) 25%, transparent);
  }

  .ui-textarea:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
}
