@component UI.Input {
  id: string = ""
  name: string = ""
  value: string = ""
  placeholder: string = ""
  type: string = "text"
  disabled: bool = false
  required: bool = false
  class: string = ""
}

@if disabled {
  @if id != "" {
    <input
      class={"ui-input " + class}
      id={id}
      name={name}
      value={value}
      placeholder={placeholder}
      type={type}
      data-ws-bind
      disabled
    />
  } @else {
    <input
      class={"ui-input " + class}
      name={name}
      value={value}
      placeholder={placeholder}
      type={type}
      data-ws-bind
      disabled
    />
  }
} @else {
  @if required {
    @if id != "" {
      <input
        class={"ui-input " + class}
        id={id}
        name={name}
        value={value}
        placeholder={placeholder}
        type={type}
        data-ws-bind
        required
      />
    } @else {
      <input
        class={"ui-input " + class}
        name={name}
        value={value}
        placeholder={placeholder}
        type={type}
        data-ws-bind
        required
      />
    }
  } @else {
    @if id != "" {
      <input
        class={"ui-input " + class}
        id={id}
        name={name}
        value={value}
        placeholder={placeholder}
        type={type}
        data-ws-bind
      />
    } @else {
      <input
        class={"ui-input " + class}
        name={name}
        value={value}
        placeholder={placeholder}
        type={type}
        data-ws-bind
      />
    }
  }
}

@style {
  .ui-input {
    display: flex;
    width: 100%;
    height: 2.25rem;
    border-radius: var(--ui-radius);
    border: 1px solid var(--ui-input);
    background: transparent;
    padding: 0 0.75rem;
    font-size: 0.875rem;
    color: var(--ui-foreground);
    font-family: inherit;
    box-shadow: 0 0 0 0 transparent;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .ui-input::placeholder {
    color: var(--ui-muted-foreground);
  }

  .ui-input:focus {
    outline: none;
    border-color: var(--ui-ring);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ui-ring) 25%, transparent);
  }

  .ui-input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
}
