@component Greeting {
  placeholder: string = "Your name"
}

@client {
  name: signal<string> = ""
}

<div class="greeting">
  <UI.Label text="Name" target="greeting-name" />
  <UI.Input
    id="greeting-name"
    value={name}
    placeholder={placeholder}
    @input={|event| name = event.target.value}
  />
  <p class="greeting-output">Hello, {name}!</p>
</div>

@style {
  .greeting {
    display: grid;
    gap: 0.5rem;
    max-width: 20rem;
  }

  .greeting-output {
    margin: 0.25rem 0 0;
    font-size: 0.9375rem;
  }
}
