@component Counter {
  initial: int = 0
  label: string = "Count"
}

@client {
  count: signal<int> = initial
}

<div class="counter">
  <p class="counter-label">{label}: <strong>{count}</strong></p>
  <div class="button-row">
    <button type="button" class="ui-button" data-variant="outline" data-size="sm" @click={count++}>+</button>
    <button type="button" class="ui-button" data-variant="outline" data-size="sm" @click={count--}>-</button>
    <button type="button" class="ui-button" data-variant="ghost" data-size="sm" @click={count = 0}>Reset</button>
  </div>
</div>

@style {
  .counter {
    border: 1px solid var(--ui-border);
    padding: 1rem;
    border-radius: var(--ui-radius);
    background: var(--ui-card);
  }

  .counter-label {
    margin: 0 0 0.75rem;
    font-size: 0.9375rem;
  }
}
