@component Counter {
  initial: int = 0
  label: string = "Count"
}

@client {
  count: signal<int> = initial
}

<div class="counter">
  <p>{label}: {count}</p>
  <button @click={|event| count++}>+</button>
  <button @click={count--}>-</button>
  <button @click={count = 0}>Reset</button>
</div>

@style {
  .counter {
    border: 1px solid #ccc;
    padding: 0.5rem;
    border-radius: 4px;
  }
}
