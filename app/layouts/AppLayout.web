@layout AppLayout {
}

<header class="app-layout bg-red-500" data-ws-nav-region>
  <nav aria-label="Main">
    <a href="/">Home</a>
    <a href="/todos">Todos</a>
    <a href="/todos/live">Live todos</a>
    <a href="/ui">UI</a>
    <a href="/counter">Counter</a>
    <a href="/async-demo">Async demo</a>
    <a href="/fetch-demo">Fetch demo</a>
    <a href="/posts/intro">Posts</a>
    @if session.userId != 0 {
      <a href="/dashboard">Dashboard</a>
      <form method="post" action="/dashboard" class="nav-logout">
        <input type="hidden" name="_action" value="logout" />
        <button type="submit" class="nav-logout-button">Log out</button>
      </form>
    } @else {
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    }
  </nav>
</header>

<slot />

@style global {
  :root {
    --ui-background: #ffffff;
    --ui-foreground: #0a0a0a;
    --ui-card: #ffffff;
    --ui-card-foreground: #0a0a0a;
    --ui-primary: #171717;
    --ui-primary-foreground: #fafafa;
    --ui-secondary: #f5f5f5;
    --ui-secondary-foreground: #171717;
    --ui-muted: #f5f5f5;
    --ui-muted-foreground: #737373;
    --ui-accent: #f5f5f5;
    --ui-accent-foreground: #171717;
    --ui-destructive: #dc2626;
    --ui-destructive-foreground: #fafafa;
    --ui-border: #e5e5e5;
    --ui-input: #e5e5e5;
    --ui-ring: #171717;
    --ui-radius: 0.5rem;
  }

  body {
    margin: 0;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--ui-background);
    color: var(--ui-foreground);
    line-height: 1.5;
  }

  main {
    max-width: 56rem;
    margin: 0 auto;
    padding: 1.5rem;
  }

  .app-layout {
    border-bottom: 1px solid var(--ui-border);
    padding: 0.75rem 1.5rem;
  }

  .app-layout nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .app-layout a {
    color: var(--ui-foreground);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .app-layout a:hover {
    color: var(--ui-primary);
  }

  .nav-logout {
    display: inline;
    margin: 0;
  }

  .nav-logout-button {
    background: none;
    border: none;
    padding: 0;
    color: var(--ui-foreground);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
  }

  .nav-logout-button:hover {
    color: var(--ui-primary);
  }

  .form-stack {
    display: grid;
    gap: 0.75rem;
    max-width: 24rem;
    margin-bottom: 1rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
}
