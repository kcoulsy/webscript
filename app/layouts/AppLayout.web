@style global {
  :root {
    --ui-background: #ffffff;
    --ui-foreground: #0a0a0a;
    --ui-card: #ffffff;
    --ui-card-foreground: #0a0a0a;
    --ui-primary: #171717;
    --ui-primary-foreground: #fafafa;
    --ui-secondary: #f5f5f5;
    --ui-secondary-foreground: #171717;
    --ui-muted: #f5f5f5;
    --ui-muted-foreground: #737373;
    --ui-accent: #f5f5f5;
    --ui-accent-foreground: #171717;
    --ui-destructive: #dc2626;
    --ui-destructive-foreground: #fafafa;
    --ui-border: #e5e5e5;
    --ui-input: #e5e5e5;
    --ui-ring: #171717;
    --ui-radius: 0.5rem;
  }

  body {
    margin: 0;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--ui-background);
    color: var(--ui-foreground);
    line-height: 1.5;
  }

  main {
    max-width: 56rem;
    margin: 0 auto;
    padding: 1.5rem;
  }

  .app-layout {
    border-bottom: 1px solid var(--ui-border);
    padding: 0.75rem 1.5rem;
  }

  .app-layout nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .app-layout a {
    color: var(--ui-foreground);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .app-layout a:hover {
    color: var(--ui-primary);
  }

  .ui-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    white-space: nowrap;
    border-radius: var(--ui-radius);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.25rem;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease, opacity 150ms ease;
    cursor: pointer;
    border: 1px solid transparent;
    font-family: inherit;
  }

  .ui-button:disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  .ui-button[data-size="default"] {
    height: 2.25rem;
    padding: 0 1rem;
  }

  .ui-button[data-size="sm"] {
    height: 2rem;
    padding: 0 0.75rem;
    font-size: 0.8125rem;
  }

  .ui-button[data-variant="default"] {
    background: var(--ui-primary);
    color: var(--ui-primary-foreground);
  }

  .ui-button[data-variant="outline"] {
    background: transparent;
    color: var(--ui-foreground);
    border-color: var(--ui-border);
  }

  .ui-button[data-variant="outline"]:hover {
    background: var(--ui-accent);
    color: var(--ui-accent-foreground);
  }

  .ui-button[data-variant="ghost"] {
    background: transparent;
    color: var(--ui-foreground);
  }

  .ui-button[data-variant="ghost"]:hover {
    background: var(--ui-accent);
    color: var(--ui-accent-foreground);
  }

  .ui-button[data-variant="destructive"] {
    background: var(--ui-destructive);
    color: var(--ui-destructive-foreground);
  }

  .ui-input {
    display: flex;
    width: 100%;
    height: 2.25rem;
    border-radius: var(--ui-radius);
    border: 1px solid var(--ui-input);
    background: transparent;
    padding: 0 0.75rem;
    font-size: 0.875rem;
    color: var(--ui-foreground);
    font-family: inherit;
    box-sizing: border-box;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .ui-input::placeholder {
    color: var(--ui-muted-foreground);
  }

  .ui-input:focus {
    outline: none;
    border-color: var(--ui-ring);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ui-ring) 25%, transparent);
  }

  .form-stack {
    display: grid;
    gap: 0.75rem;
    max-width: 24rem;
    margin-bottom: 1rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
}
